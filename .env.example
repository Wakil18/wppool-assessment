SHOPIFY_API_KEY="000000000000000000000000000000000000"

SHOPIFY_API_SECRET="shpss_000000000000000000000000000"

SHOPIFY_APP_URL="https://mirta-nonpunctuating-dahta.ngrok-free.dev"

SCOPES="write_metaobject_definitions,write_metaobjects,write_products,read_orders,write_cart_transforms,read_customers"

DB_URL="mysql://root:password@host:3306/m2s"

# Using for registering the cart transform function 
CART_TRANSFORM_FUNCTION_ID="019d0765-0000-0000-8fe2-0000000"

# Not Using
CART_TRANSFORM_FUNCTION_HANDLE="m2s-cart-transform"

# ── Integration endpoints ──────────────────────────────────────────────────
# HoodslyHub: leave blank to use the built-in mock endpoint in dev
HOODSLYHUB_ENDPOINT=""

# BirdEye: leave blank to use the built-in mock endpoint in dev
BIRDEYE_ENDPOINT=""

# Set to "true" to force the mock endpoints to return 503 (for testing retries)
MOCK_HOODSLYHUB_FAIL=false
MOCK_BIRDEYE_FAIL=false

# HubSpot CRM integration (optional — sync is skipped if not set)
HUBSPOT_API_KEY=

# CRON_SECRET protects /api/retry-processor — set to a random string in prod
CRON_SECRET=

# Override the retry delay for testing (in milliseconds)
RETRY_DELAY_OVERRIDE_MS=2000
